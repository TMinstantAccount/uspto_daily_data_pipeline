# Copy this file to .env and fill in real values. Do not commit .env to Git.
# Required for Docker on Linux (optional on Windows)
AIRFLOW_UID=50000

# Gmail App Password (or SMTP password) for Airflow failure emails
# Get App Password: Google Account → Security → 2-Step Verification → App passwords
AIRFLOW_SMTP_PASSWORD=your-app-password-here

# USPTO API key (if your download step uses the API)
USPTO_API_KEY=your-uspto-api-key-here
